# Application General Configuration
# Project brand name
PROJECT_NAME="Loco Works Management System"
# API Version Prefix
API_V1_STR="/api/v1"

# Database Configuration
# Username for PostgreSQL access
POSTGRES_USER=locouser
# Password for PostgreSQL access (Specify a secure password here)
POSTGRES_PASSWORD=your_secure_postgres_password_here
# Database name for the application
POSTGRES_DB=locodb

# Database Replication Configuration
# Replication username used for db master/slave replication sync
POSTGRES_REPLICATION_USER=repl_user
# Replication password used for db master/slave replication sync (Specify a secure replication password here)
POSTGRES_REPLICATION_PASSWORD=your_secure_replication_password_here

# Connection URLs for primary (write) and replica (read) databases using secure passwords
DATABASE_PRIMARY_URL=postgresql+asyncpg://locouser:your_secure_postgres_password_here@db-primary:5432/locodb
DATABASE_REPLICA_URL=postgresql+asyncpg://locouser:your_secure_postgres_password_here@db-replica:5432/locodb

# Redis Configuration
# Sentinel configuration addresses (comma-separated list of host:port)
REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# Sentinel master set name
REDIS_MASTER_SET=mymaster
# Password for Sentinel and Redis nodes (Specify a secure password here)
REDIS_PASSWORD=your_secure_redis_password_here
# Default standalone Redis fallback URL
REDIS_URL=redis://redis:6379/0

# Security Configuration
# JWT signing key (Specify a secure hex string here)
SECRET_KEY=your_secure_jwt_secret_key_here
# Token signature algorithm
ALGORITHM=HS256
# Expiry window for access tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Enable unbuffered Python logging outputs
PYTHONUNBUFFERED=1

# Ngrok Public URL and Credentials
# Authtoken for the ngrok tunnel agent
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# API Key for checking logs/status via ngrok API
NGROK_APIKEY=your_ngrok_apikey_here
# Custom reserved domain URL registered on the ngrok account
NGROK_URL=your_ngrok_domain_here

# Nginx Gateway Ports
# Public HTTP mapped port
NGINX_HTTP_PORT=8080
# Public HTTPS mapped port
NGINX_HTTPS_PORT=8443
