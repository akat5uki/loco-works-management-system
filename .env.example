# ==============================================================================
# LOCO WORKS MANAGEMENT SYSTEM (LWMS) - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and populate with production secrets and credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION GENERAL CONFIGURATION
# ------------------------------------------------------------------------------
# Brand title displayed across API documentation and emails
PROJECT_NAME="Loco Works Management System"
# API Version Routing Prefix
API_V1_STR="/api/v1"
# Host network interface binding for backend web application
BACKEND_HOST="0.0.0.0"
# Port for FastAPI application server
BACKEND_PORT=8000
# Comma-separated list of valid locomotive testing & commission stages
LOCO_STAGES="0,5,6,7,9"
# Enable unbuffered Python logging outputs
PYTHONUNBUFFERED=1

# ------------------------------------------------------------------------------
# 2. DATABASE CONFIGURATION & REPLICATION
# ------------------------------------------------------------------------------
# PostgreSQL database user
POSTGRES_USER=locouser
# PostgreSQL database user password (REPLACE WITH SECURE GENERATED PASSWORD)
POSTGRES_PASSWORD=change_this_to_a_secure_password
# Application database name
POSTGRES_DB=locodb
# Replication username used for db master/replica synchronization
POSTGRES_REPLICATION_USER=repl_user
# Replication password used for db master/replica synchronization
POSTGRES_REPLICATION_PASSWORD=change_this_to_a_secure_repl_password

# Connection URLs for primary (write) and replica (read) databases
DATABASE_PRIMARY_URL=postgresql+asyncpg://locouser:change_this_to_a_secure_password@db-primary:5432/locodb
DATABASE_REPLICA_URL=postgresql+asyncpg://locouser:change_this_to_a_secure_password@db-replica:5432/locodb

# Engine Connection Pool Configuration
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=False

# ------------------------------------------------------------------------------
# 3. REDIS SENTINEL CLUSTERING & CACHING CONFIGURATION
# ------------------------------------------------------------------------------
# Sentinel cluster addresses (comma-separated list of host:port)
REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# Sentinel master monitor set name
REDIS_MASTER_SET=mymaster
# Password for Redis Master and Sentinel nodes (REPLACE WITH SECURE PASSWORD)
REDIS_PASSWORD=change_this_to_a_secure_redis_password
# Standalone fallback Redis URL
REDIS_URL=redis://redis:6379/0
# Timeout (in seconds) for socket network operations
REDIS_SOCKET_TIMEOUT=10.0

# ------------------------------------------------------------------------------
# 4. SECURITY & SESSION AUTHENTICATION SHIELD
# ------------------------------------------------------------------------------
# Secret key used for signing JWT tokens and session hashes (Generate via: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_random_32_byte_hex_string
# Cryptographic algorithm for JWT signature creation
ALGORITHM=HS256
# Expiry window (in minutes) for JWT access tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Duration (in seconds) for active session sliding expiration (default: 30 minutes)
SESSION_EXPIRE_SECONDS=1800
# Force Secure flag on first-party Strict cookies (Set to True in HTTPS environments)
COOKIE_SECURE_STRICT=False
# Force Secure flag on cross-site / embedded Partitioned cookies (Must be True for CHIPS compliance)
COOKIE_SECURE_EMBED=True
# Single-use write lag window cookie duration (in seconds)
WRITE_WINDOW_LAG_SECONDS=2

# ------------------------------------------------------------------------------
# 5. EMAIL OTP VERIFICATION SYSTEM
# ------------------------------------------------------------------------------
# Toggle email verification feature flag (1 = Enabled, 0 = Disabled)
ENABLE_EMAIL_OTP=0
# SMTP gateway hostname (e.g. smtp.sendgrid.net, smtp.gmail.com, or mailpit)
SMTP_HOST=mailpit
# SMTP port (587 for TLS, 465 for SSL, 1025 for Mailpit)
SMTP_PORT=1025
# SMTP account username
SMTP_USERNAME=""
# SMTP account password / app-specific token
SMTP_PASSWORD=""
# Default sender email address
SMTP_FROM_EMAIL=no-reply@locoworks.com
# Enable TLS encryption for outgoing emails
SMTP_USE_TLS=False
# Enable SSL encryption for outgoing emails
SMTP_USE_SSL=False

# OTP and Registration Session Expiry configuration (in seconds)
# Time window in which user must enter the OTP code (default: 3 minutes)
OTP_EXPIRE_SECONDS=180
# Time window in which temporary registration data is cached in Redis (default: 5 minutes)
REGISTRATION_SESSION_EXPIRE_SECONDS=300

# ------------------------------------------------------------------------------
# 6. NGINX GATEWAY & EXTERNAL SERVICE PORTS
# ------------------------------------------------------------------------------
# Nginx public mapped HTTP port
NGINX_HTTP_PORT=80
# Nginx public mapped HTTPS port
NGINX_HTTPS_PORT=443
# Ngrok Authtoken for public tunnel agent
NGROK_AUTHTOKEN=""
# Ngrok API Key for management
NGROK_APIKEY=""
# Reserved custom subdomain on ngrok
NGROK_URL=""

# ------------------------------------------------------------------------------
# 7. FRONTEND CLIENT CONFIGURATION
# ------------------------------------------------------------------------------
# Base API URL consumed by Axios client in Vite frontend
VITE_API_BASE_URL=/api/v1

# ------------------------------------------------------------------------------
# 8. ADMINISTRATOR PERSONNEL & REGISTRATION STAGING CONFIGURATION
# ------------------------------------------------------------------------------
# Default Administrator account ticket number
DEFAULT_ADMIN_TICKET=9999
# Default Administrator account email address
DEFAULT_ADMIN_EMAIL=admin@locoworks.local
# Default Administrator initial setup password
DEFAULT_ADMIN_PASSWORD=AdminPassword
# Employee registration request verification validity duration (in days)
REGISTRATION_VALIDITY_DAYS=7
